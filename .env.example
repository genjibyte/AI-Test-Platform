# Phase 2.5 formal mini-benchmark config.
# Copy this file to ".env" (which is gitignored) and fill in your real key.
# app/config.py reads .env automatically via Settings(env_file=".env").
# The key stays local: never committed, never logged (only sent as a Bearer header).

TESTAGENT_LLM_PROVIDER=deepseek
TESTAGENT_LLM_MODEL=deepseek-v4-pro
TESTAGENT_LLM_API_KEY=sk-replace-with-your-deepseek-key

# Optional: DeepSeek default base URL is https://api.deepseek.com
# TESTAGENT_LLM_BASE_URL=https://api.deepseek.com

# Maven path (so you don't have to export it each run)
TESTAGENT_MAVEN_CMD=C:\Users\lenovo\AppData\Local\Programs\Maven\apache-maven-3.9.9\bin\mvn.cmd

# Phase 2.5 benchmark-only Maven args: prioritise compile/exec/pass. The
# benchmark runner passes these explicitly; normal API/run_judge/Phase 2 e2e
# paths do not read them. Skip policy/style/audit plugins (F1: RAT header check)
# AND JaCoCo (F2: duplicate-agent crash on repos that already configure JaCoCo).
# Skipping JaCoCo means coverage is marked coverage_unavailable for these repos.
TESTAGENT_MVN_EXTRA_ARGS=-Drat.skip=true -Dcheckstyle.skip=true -Dspotbugs.skip=true -Dlicense.skip=true -Denforcer.skip=true -Danimal.sniffer.skip=true -Dmaven.javadoc.skip=true -Dpmd.skip=true -Djacoco.skip=true
